    <feature supported="carousel">
    <view name="system">
      <carousel name="systemcarousel">
        <type>vertical</type>
        <origin>0 0</origin>
        <pos>0.12 0</pos>
        <size>0.27 0.99</size>

        <!-- Mejor en vertical -->
        <logoAlignment>center</logoAlignment>

        <maxLogoCount>5</maxLogoCount>
        <color>00000000</color>

        <!-- Tamaño base -->
        <logoSize>0.26 0.18</logoSize>

        <!-- Escala del seleccionado -->
        <logoScale>1.85</logoScale>

        <!-- Opacidad de vecinos -->
        <minLogoOpacity>0.72</minLogoOpacity>

        <!-- Separación compensada -->
        <scaledLogoSpacing>1.10</scaledLogoSpacing>

        <!-- NUEVO: separación vertical fija -->
        <logoSpacingY>0.205</logoSpacingY>

        <!-- NUEVO: mueve todo el bloque -->
        <logoOffsetX>0.005</logoOffsetX>
        <logoOffsetY>0.005</logoOffsetY>

        <!-- NUEVO: ajuste fino solo del seleccionado -->
        <selectedLogoOffsetX>0.035</selectedLogoOffsetX>
        <selectedLogoOffsetY>0.000</selectedLogoOffsetY>
      </carousel>
    </view>
  </feature>

